# Base URL of the Roam Hono API (apps/api). The web app fetches trail data from
# it server-side at build/revalidate time. Falls back to bundled fixtures if the
# API is unreachable, so the marketing page always renders.
ROAM_API_URL=http://localhost:3000

# Public site URL — used for canonical URLs, Open Graph and sitemap.
NEXT_PUBLIC_SITE_URL=https://roamhike.com

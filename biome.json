{
  "$schema": "https://biomejs.dev/schemas/1.9.0/schema.json",
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all"
    }
  },
  "files": {
    "ignore": [
      "node_modules",
      "**/node_modules",
      "**/ios",
      "**/android",
      "**/dist",
      "**/build",
      "**/.next",
      "**/.expo",
      "poc-api",
      "poc-mobile",
      "**/data",
      "**/generated",
      "packages/tokens/tokens.css",
      "apps/mobile/assets/content",
      "packages/db/content",
      "**/content/workflows"
    ]
  }
}
